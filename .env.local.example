# Vapi private API key — server-side only, never exposed to the browser.
# Find it in the Vapi dashboard under Settings > API Keys ("Private Key").
VAPI_PRIVATE_KEY=your-vapi-private-key-here

# Restrict the dashboard to one assistant. This is Riley's ID from your setup.
VAPI_ASSISTANT_ID=63351c83-f19c-4532-90bf-d1a28c2ab35c

# How many recent calls to pull each refresh (optional, default 200).
VAPI_FETCH_LIMIT=200
